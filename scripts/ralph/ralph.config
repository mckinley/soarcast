# Ralph project config for SoarCast
# Uncomment and set RALPH_MODEL to use a cheaper model for mechanical tasks:
# RALPH_MODEL="claude-haiku-4-5-20251001"   # fast + cheap, good for simple tasks
# RALPH_MODEL="claude-sonnet-4-6"           # default, good balance
# RALPH_MODEL="claude-opus-4-5-20251101"    # most capable, use for complex tasks

# Deploy command (runs after all tasks complete)
RALPH_DEPLOY_CMD="vercel --prod --yes"
RALPH_DEPLOY_URL="https://soarcast.vercel.app"
RALPH_SMOKE_TEST="scripts/ralph/smoke-test.sh"
