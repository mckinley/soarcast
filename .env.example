# ========================================
# Turso Database Configuration
# ========================================
# Create a database: turso db create soarcast
# Get the URL: turso db show soarcast
TURSO_DATABASE_URL=libsql://your-database.turso.io

# Create an auth token: turso db tokens create soarcast
TURSO_AUTH_TOKEN=your-turso-auth-token

# ========================================
# NextAuth Configuration (Auth.js v5)
# ========================================
# Generate a secure random secret: openssl rand -base64 32
# This is used to encrypt session cookies and tokens
AUTH_SECRET=your-nextauth-secret

# Base URL for OAuth callbacks
# Development: http://localhost:3000
# Production: https://your-domain.com
AUTH_URL=http://localhost:3000

# ========================================
# Google OAuth Provider
# ========================================
# Create OAuth credentials at: https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: {AUTH_URL}/api/auth/callback/google
AUTH_GOOGLE_ID=your-google-oauth-client-id
AUTH_GOOGLE_SECRET=your-google-oauth-client-secret

# ========================================
# GitHub OAuth Provider
# ========================================
# Create OAuth app at: https://github.com/settings/developers
# Authorization callback URL: {AUTH_URL}/api/auth/callback/github
AUTH_GITHUB_ID=your-github-oauth-app-id
AUTH_GITHUB_SECRET=your-github-oauth-app-secret

# ========================================
# Web Push Notifications (VAPID)
# ========================================
# Generate VAPID keys: npx web-push generate-vapid-keys
# Public key is exposed to the client (NEXT_PUBLIC_ prefix required)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key

# Private key stays server-side only
VAPID_PRIVATE_KEY=your-vapid-private-key

# ========================================
# Email (Resend) - for morning digest emails
# ========================================
# Sign up at https://resend.com and create an API key
# Set up a sending domain or use the Resend sandbox domain
RESEND_API_KEY=your-resend-api-key

# ========================================
# Cron Job Security
# ========================================
# Random secret to protect the notification check endpoint
# Generate with: openssl rand -base64 32
# Vercel auto-generates this if not set
CRON_SECRET=your-cron-secret
