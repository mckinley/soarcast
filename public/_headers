# Hashed assets — content hash in filename means safe to cache forever
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Marker images (also hashed via Vite copy)
/marker-icon.png
  Cache-Control: public, max-age=31536000, immutable
/marker-icon-2x.png
  Cache-Control: public, max-age=31536000, immutable
/marker-shadow.png
  Cache-Control: public, max-age=31536000, immutable

# Service worker — must revalidate
/sw.js
  Cache-Control: no-cache

# Manifest
/manifest.json
  Cache-Control: public, max-age=3600
